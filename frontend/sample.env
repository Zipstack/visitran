# Backend API base URL for React to communicate with the backend server
REACT_APP_BACKEND_URL=http://localhost:8000

# Socket server base URL for WebSocket connections
# [DOCKER]  Not used — production build auto-detects from window.location
# [LOCAL]   Points to the standalone Socket.IO server (eventlet on port 4000)
REACT_APP_SOCKET_SERVICE_BASE_URL=http://localhost:4000

# PostHog analytics — enabled by default. Set to "false" to opt out.
#REACT_APP_POSTHOG_ENABLED=false
