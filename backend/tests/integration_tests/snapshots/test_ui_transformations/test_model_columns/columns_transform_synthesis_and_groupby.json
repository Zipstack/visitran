  "sql_statement": "SELECT\n  t0.profession\nFROM (\n  SELECT\n    t1.id AS id,\n    t1.name AS name,\n    t1.age AS age,\n    t1.profession AS profession,\n    t1.salary AS salary,\n    CONCAT(CONCAT(t1.name, ' '), t1.profession) AS full_name\n  FROM main.employee AS t1\n) AS t0\nGROUP BY\n  1"
