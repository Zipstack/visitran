{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "connection_type": {
      "type": "string",
      "title": "Connection Type",
      "minLength": 1,
      "format": "radio"
    },
    "connection_url": {
      "type": "string",
      "title": "Url",
      "description": "host url for the instance\n[eg.: snowflake://username:password@account/db/schema?warehouse={warehouse}&role={role}]",
      "minLength": 1,
      "url_format": "snowflake://username:password@account/db/schema?warehouse={warehouse}&role={role}"
    },
    "account": {
      "type": "string",
      "title": "Account Identifier",
      "description": "Account Identifier (Remove 'snowflakecomputing.com') - Copy from Snowflake -> Account -> Account Identifier",
      "minLength": 1
    },
    "username": {
      "type": "string",
      "title": "Username",
      "description": "Username",
      "minLength": 1
    },
    "password": {
      "type": "string",
      "title": "Password",
      "description": "Password",
      "format": "password"
    },
    "warehouse": {
      "type": "string",
      "title": "Warehouse",
      "description": "Warehouse",
      "minLength": 1
    },
    "database": {
      "type": "string",
      "title": "Database",
      "description": "Database",
      "minLength": 1
    },
    "schema": {
      "type": "string",
      "title": "Schema",
      "description": "Schema",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "title": "Role",
      "description": "Role",
      "minLength": 1
    }
  },
  "required": ["username", "password", "account", "warehouse", "database", "role", "connection_url", "connection_type"]
}
