      "model_data": {
        "sql": "SELECT\n  \"t4\".\"customer_id\",\n  \"t4\".\"store_id\",\n  \"t4\".\"first_name\",\n  \"t4\".\"last_name\",\n  \"t4\".\"email\",\n  \"t4\".\"address_id\",\n  \"t4\".\"active\",\n  \"t4\".\"create_date\",\n  \"t4\".\"last_update\",\n  \"t5\".\"address_id\" AS \"address_address_id\",\n  \"t5\".\"address\",\n  \"t5\".\"address2\",\n  \"t5\".\"district\",\n  \"t5\".\"city_id\",\n  \"t5\".\"postal_code\",\n  \"t5\".\"phone\",\n  \"t5\".\"location\",\n  \"t5\".\"last_update\" AS \"address_last_update\",\n  \"t6\".\"city_id\" AS \"city_city_id\",\n  \"t6\".\"city\",\n  \"t6\".\"country_id\",\n  \"t6\".\"last_update\" AS \"city_last_update\",\n  \"t7\".\"country_id\" AS \"country_country_id\",\n  \"t7\".\"country\",\n  \"t7\".\"last_update\" AS \"country_last_update\"\nFROM \"raw\".\"customer\" AS \"t4\"\nLEFT OUTER JOIN \"raw\".\"address\" AS \"t5\"\n  ON \"t4\".\"address_id\" = \"t5\".\"address_id\"\nLEFT OUTER JOIN \"raw\".\"city\" AS \"t6\"\n  ON \"t5\".\"city_id\" = \"t6\".\"city_id\"\nLEFT OUTER JOIN \"raw\".\"country\" AS \"t7\"\n  ON \"t6\".\"country_id\" = \"t7\".\"country_id\""
      },
