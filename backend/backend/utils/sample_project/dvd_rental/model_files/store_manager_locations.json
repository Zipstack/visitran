    {
      "status": "sql",
      "model_data": {
        "sql": "SELECT\n  \"t10\".\"store_id\",\n  \"t10\".\"manager_staff_id\",\n  \"t10\".\"address_id\",\n  \"t10\".\"last_update\",\n  \"t10\".\"staff_id\",\n  \"t10\".\"first_name\" AS \"manager_first_name\",\n  \"t10\".\"last_name\" AS \"manager_last_name\",\n  \"t10\".\"staff_address_id\",\n  \"t10\".\"email\",\n  \"t10\".\"staff_store_id\",\n  \"t10\".\"active\",\n  \"t10\".\"username\",\n  \"t10\".\"password\",\n  \"t10\".\"staff_last_update\",\n  \"t10\".\"address_address_id\",\n  \"t10\".\"address\",\n  \"t10\".\"address2\",\n  \"t10\".\"district\",\n  \"t10\".\"city_id\",\n  \"t10\".\"postal_code\",\n  \"t10\".\"phone\",\n  \"t10\".\"location\",\n  \"t10\".\"address_last_update\",\n  \"t10\".\"city_city_id\",\n  \"t10\".\"city\",\n  \"t10\".\"country_id\",\n  \"t10\".\"city_last_update\",\n  \"t10\".\"country_country_id\",\n  \"t10\".\"country\",\n  \"t10\".\"country_last_update\"\nFROM (\n  SELECT\n    \"t5\".\"store_id\",\n    \"t5\".\"manager_staff_id\",\n    \"t5\".\"address_id\",\n    \"t5\".\"last_update\",\n    \"t6\".\"staff_id\",\n    \"t6\".\"first_name\",\n    \"t6\".\"last_name\",\n    \"t6\".\"address_id\" AS \"staff_address_id\",\n    \"t6\".\"email\",\n    \"t6\".\"store_id\" AS \"staff_store_id\",\n    \"t6\".\"active\",\n    \"t6\".\"username\",\n    \"t6\".\"password\",\n    \"t6\".\"last_update\" AS \"staff_last_update\",\n    \"t7\".\"address_id\" AS \"address_address_id\",\n    \"t7\".\"address\",\n    \"t7\".\"address2\",\n    \"t7\".\"district\",\n    \"t7\".\"city_id\",\n    \"t7\".\"postal_code\",\n    \"t7\".\"phone\",\n    \"t7\".\"location\",\n    \"t7\".\"last_update\" AS \"address_last_update\",\n    \"t8\".\"city_id\" AS \"city_city_id\",\n    \"t8\".\"city\",\n    \"t8\".\"country_id\",\n    \"t8\".\"last_update\" AS \"city_last_update\",\n    \"t9\".\"country_id\" AS \"country_country_id\",\n    \"t9\".\"country\",\n    \"t9\".\"last_update\" AS \"country_last_update\"\n  FROM \"raw\".\"store\" AS \"t5\"\n  LEFT OUTER JOIN \"raw\".\"staff\" AS \"t6\"\n    ON \"t5\".\"manager_staff_id\" = \"t6\".\"staff_id\"\n  LEFT OUTER JOIN \"raw\".\"address\" AS \"t7\"\n    ON \"t5\".\"address_id\" = \"t7\".\"address_id\"\n  LEFT OUTER JOIN \"raw\".\"city\" AS \"t8\"\n    ON \"t7\".\"city_id\" = \"t8\".\"city_id\"\n  LEFT OUTER JOIN \"raw\".\"country\" AS \"t9\"\n    ON \"t8\".\"country_id\" = \"t9\".\"country_id\"\n) AS \"t10\""
      },
      "transformation_id": "sql"
    }
  ]
