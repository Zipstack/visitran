    {
      "status": "sql",
      "model_data": {
        "sql": "SELECT\n  *\nFROM (\n  SELECT\n    \"t6\".\"first_name\",\n    \"t6\".\"last_name\",\n    COUNT(\"t6\".\"rental_id\") AS \"total_rentals\",\n    SUM(\"t6\".\"amount\") AS \"total_payment_amount\"\n  FROM (\n    SELECT\n      \"t3\".\"customer_id\",\n      \"t3\".\"store_id\",\n      \"t3\".\"first_name\",\n      \"t3\".\"last_name\",\n      \"t3\".\"email\",\n      \"t3\".\"address_id\",\n      \"t3\".\"active\",\n      \"t3\".\"create_date\",\n      \"t3\".\"last_update\",\n      \"t4\".\"rental_id\",\n      \"t4\".\"rental_date\",\n      \"t4\".\"inventory_id\",\n      \"t4\".\"customer_id\" AS \"rental_customer_id\",\n      \"t4\".\"return_date\",\n      \"t4\".\"staff_id\",\n      \"t4\".\"last_update\" AS \"rental_last_update\",\n      \"t5\".\"payment_id\",\n      \"t5\".\"customer_id\" AS \"payment_customer_id\",\n      \"t5\".\"staff_id\" AS \"payment_staff_id\",\n      \"t5\".\"rental_id\" AS \"payment_rental_id\",\n      \"t5\".\"amount\",\n      \"t5\".\"payment_date\",\n      \"t5\".\"last_update\" AS \"payment_last_update\"\n    FROM \"raw\".\"customer\" AS \"t3\"\n    LEFT OUTER JOIN \"raw\".\"rental\" AS \"t4\"\n      ON \"t3\".\"customer_id\" = \"t4\".\"customer_id\"\n    LEFT OUTER JOIN \"raw\".\"payment\" AS \"t5\"\n      ON \"t4\".\"rental_id\" = \"t5\".\"rental_id\"\n  ) AS \"t6\"\n  GROUP BY\n    1,\n    2\n) AS \"t7\"\nORDER BY\n  \"t7\".\"total_payment_amount\" DESC NULLS LAST"
      },
      "transformation_id": "sql"
    }
