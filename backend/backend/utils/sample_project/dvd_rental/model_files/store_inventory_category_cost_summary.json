    {
      "status": "sql",
      "model_data": {
        "sql": "SELECT\n  *\nFROM (\n  SELECT\n    \"t9\".\"store_id\",\n    \"t9\".\"category\",\n    COUNT(\"t9\".\"inventory_id\") AS \"films\",\n    AVG(\"t9\".\"replacement_cost\") AS \"avg_replacement_cost\",\n    SUM(\"t9\".\"replacement_cost\") AS \"total_replacement_cost\"\n  FROM (\n    SELECT\n      \"t8\".\"inventory_id\",\n      \"t8\".\"film_id\",\n      \"t8\".\"store_id\",\n      \"t8\".\"last_update\",\n      \"t8\".\"film_film_id\",\n      \"t8\".\"title\",\n      \"t8\".\"description\",\n      \"t8\".\"release_year\",\n      \"t8\".\"language_id\",\n      \"t8\".\"original_language_id\",\n      \"t8\".\"rental_duration\",\n      \"t8\".\"rental_rate\",\n      \"t8\".\"length\",\n      \"t8\".\"replacement_cost\",\n      \"t8\".\"rating\",\n      \"t8\".\"special_features\",\n      \"t8\".\"film_last_update\",\n      \"t8\".\"film_category_film_id\",\n      \"t8\".\"category_id\",\n      \"t8\".\"film_category_last_update\",\n      \"t8\".\"category_category_id\",\n      \"t8\".\"name\" AS \"category\",\n      \"t8\".\"category_last_update\"\n    FROM (\n      SELECT\n        \"t4\".\"inventory_id\",\n        \"t4\".\"film_id\",\n        \"t4\".\"store_id\",\n        \"t4\".\"last_update\",\n        \"t5\".\"film_id\" AS \"film_film_id\",\n        \"t5\".\"title\",\n        \"t5\".\"description\",\n        \"t5\".\"release_year\",\n        \"t5\".\"language_id\",\n        \"t5\".\"original_language_id\",\n        \"t5\".\"rental_duration\",\n        \"t5\".\"rental_rate\",\n        \"t5\".\"length\",\n        \"t5\".\"replacement_cost\",\n        \"t5\".\"rating\",\n        \"t5\".\"special_features\",\n        \"t5\".\"last_update\" AS \"film_last_update\",\n        \"t6\".\"film_id\" AS \"film_category_film_id\",\n        \"t6\".\"category_id\",\n        \"t6\".\"last_update\" AS \"film_category_last_update\",\n        \"t7\".\"category_id\" AS \"category_category_id\",\n        \"t7\".\"name\",\n        \"t7\".\"last_update\" AS \"category_last_update\"\n      FROM \"raw\".\"inventory\" AS \"t4\"\n      LEFT OUTER JOIN \"raw\".\"film\" AS \"t5\"\n        ON \"t4\".\"film_id\" = \"t5\".\"film_id\"\n      LEFT OUTER JOIN \"raw\".\"film_category\" AS \"t6\"\n        ON \"t4\".\"film_id\" = \"t6\".\"film_id\"\n      LEFT OUTER JOIN \"raw\".\"category\" AS \"t7\"\n        ON \"t6\".\"category_id\" = \"t7\".\"category_id\"\n    ) AS \"t8\"\n  ) AS \"t9\"\n  GROUP BY\n    1,\n    2\n) AS \"t10\"\nORDER BY\n  \"t10\".\"total_replacement_cost\" DESC NULLS LAST"
      },
      "transformation_id": "sql"
    }
