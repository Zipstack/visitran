class Film(VisitranModel):
    def __init__(self):
        super().__init__()
        self.materialization = Materialization.EPHEMERAL
        self.source_schema_name = "raw"
        self.source_table_name = "film"
        self.destination_schema_name = "dev"
        self.destination_table_name = "film"
