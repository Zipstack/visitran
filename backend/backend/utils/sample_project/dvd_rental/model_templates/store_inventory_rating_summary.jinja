MODEL_NAME = "store_inventory_rating_summary"

class DevStoreInventoryRatingSummary(VisitranModel):
    def __init__(self):
        super().__init__()
        self.materialization = Materialization.EPHEMERAL
        self.source_schema_name = "raw"
