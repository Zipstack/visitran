      "model_data": {
        "sql": "WITH t0 AS (\n  SELECT\n    t3.id AS id,\n    t3.user_id AS customer_id,\n    t3.order_date AS order_date,\n    t3.status AS status\n  FROM raw.raw_orders AS t3\n), t1 AS (\n  SELECT\n    t0.id AS order_id,\n    t0.customer_id AS customer_id,\n    t0.order_date AS order_date,\n    t0.status AS status\n  FROM t0\n)\nSELECT\n  t2.customer_id,\n  SUM(t2.amount_in_dollars) AS total_amount\nFROM (\n  SELECT\n    t3.payment_id AS payment_id,\n    t3.order_id AS order_id,\n    t3.payment_method AS payment_method,\n    t3.amount AS amount,\n    t3.amount_in_dollars AS amount_in_dollars,\n    t1.order_id AS dev_orders_order_id,\n    t1.customer_id AS customer_id,\n    t1.order_date AS order_date,\n    t1.status AS status\n  FROM dev.payments AS t3\n  JOIN t1\n    ON t3.order_id <> t1.order_id\n) AS t2\nGROUP BY\n  1"
