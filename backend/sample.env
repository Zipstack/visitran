# =============================================================================
# Visitran OSS Environment Configuration
# =============================================================================
# This file works for both Docker and local (localhost) setups.
# Look for [DOCKER] and [LOCAL] tags to see what to change per setup type.

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------
DEBUG=False
DJANGO_ENV=development
DJANGO_SETTINGS_MODULE=backend.server.settings.dev

# https://djecrety.ir/ - Use this link to generate a secret key
# Note: Replace this with your own key in production
SECRET_KEY=django-insecure-default-key-change-me-in-production-x9k2m7p4

# -----------------------------------------------------------------------------
# Security & Session Settings
# -----------------------------------------------------------------------------
CACHE_TTL_SEC=10800
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_AGE=604800

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
# [DOCKER]  DB_HOST=postgres        (service name from docker-compose.yaml)
# [LOCAL]   DB_HOST=                 (leave empty to use SQLite — no PostgreSQL needed)
# [LOCAL]   DB_HOST=localhost        (if you have PostgreSQL running locally)
DB_HOST=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# [DOCKER]  REDIS_HOST=redis        (service name from docker-compose.yaml)
# [LOCAL]   REDIS_HOST=localhost     (if you have Redis running locally)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USER=default
REDIS_DB=

# For Redis message streaming used by Visitran AI
REDIS_URL_STREAMER=redis://${REDIS_HOST}:${REDIS_PORT}/10

# -----------------------------------------------------------------------------
# System Admin Credentials
# -----------------------------------------------------------------------------
# Set your own secure values for the default admin user
SYSTEM_ADMIN_USERNAME=admin
SYSTEM_ADMIN_PASSWORD=
SYSTEM_ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Workflow Log History
# -----------------------------------------------------------------------------
ENABLE_LOG_HISTORY=True
LOG_HISTORY_CONSUMER_INTERVAL=30
LOGS_BATCH_LIMIT=30

# -----------------------------------------------------------------------------
# Sample Project Database (Optional)
# -----------------------------------------------------------------------------
# Pre-fills a demo project with sample data. Requires PostgreSQL.
# [DOCKER]  DB_SAMPLE_HOST=postgres
# [LOCAL]   DB_SAMPLE_HOST=localhost  (or leave empty to skip sample project)
DB_SAMPLE_HOST=postgres
DB_SAMPLE_USER=postgres
DB_SAMPLE_PASSWORD=postgres
DB_SAMPLE_DBNAME=postgres
DB_SAMPLE_PORT=5432
DB_SAMPLE_SCHEMA=sample_test

# -----------------------------------------------------------------------------
# AI Server Configuration
# -----------------------------------------------------------------------------
# Visitran's hosted AI service. Requires a VISITRAN_AI_KEY (see below).
AI_SERVER_BASE_URL=https://us.app.visitran.com/ai
TEMPERATURE=0.2

# API Key for connecting to Visitran AI cloud service
# Sign up at app.visitran.com, subscribe to an AI plan, and generate an API key.
# Alternatively, go to Settings > Visitran AI in your local instance to enter the key via UI.
VISITRAN_AI_KEY=

# -----------------------------------------------------------------------------
# WebSocket Configuration
# -----------------------------------------------------------------------------
# Options: 'eventlet' or 'RedisManager'
SOCKET_MANAGER=eventlet

# -----------------------------------------------------------------------------
# Encryption Keys
# -----------------------------------------------------------------------------
# Private key to encrypt connection's sensitive data
# Replace with your own key in production:
#   python -c "from base64 import b64encode; from cryptography.fernet import Fernet; print(b64encode(Fernet.generate_key()).decode())"
VISITRAN_ENCRYPTION_KEY=ZWcydGZ0M1RCZk1jMTEwV3U2dzBPMHZ0SnROTnVzU1J2d3ctT2kwbEFvUT0=

# RSA key pair for encrypting sensitive fields (connection passwords, API keys, etc.)
# The frontend encrypts sensitive data with the public key before sending to the backend.
# The backend decrypts with the private key before storing (re-encrypted with Fernet).
# Replace with your own keys in production:
#   python -c "from cryptography.hazmat.primitives.asymmetric import rsa; from cryptography.hazmat.primitives import serialization; k=rsa.generate_private_key(65537,2048); print(k.private_bytes(serialization.Encoding.PEM,serialization.PrivateFormat.PKCS8,serialization.NoEncryption()).decode()); print(k.public_key().public_bytes(serialization.Encoding.PEM,serialization.PublicFormat.SubjectPublicKeyInfo).decode())"
